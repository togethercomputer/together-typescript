{
  "dxt_version": "0.2",
  "name": "together-ai-mcp",
  "version": "0.37.0",
  "description": "The official MCP Server for the Together API",
  "author": {
    "name": "Together",
    "email": "dev-feedback@TogetherAI.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/togethercomputer/together-typescript.git"
  },
  "homepage": "https://github.com/togethercomputer/together-typescript/tree/main/packages/mcp-server#readme",
  "documentation": "https://docs.together.ai/",
  "server": {
    "type": "node",
    "entry_point": "index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/index.js"],
      "env": {
        "TOGETHER_API_KEY": "${user_config.TOGETHER_API_KEY}"
      }
    }
  },
  "user_config": {
    "TOGETHER_API_KEY": {
      "title": "api_key",
      "description": "",
      "required": true,
      "type": "string"
    }
  },
  "tools": [],
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=18.0.0"
    }
  },
  "keywords": ["api"]
}
